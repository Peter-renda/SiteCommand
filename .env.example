# Stripe billing — subscriptions, checkout, customer portal, and webhooks.
# TEST vs LIVE mode is decided entirely by WHICH keys you set here (there is no
# code toggle): sandbox uses sk_test_/whsec_ + test-mode price IDs; the real
# connection uses sk_live_/whsec_ + LIVE-mode price IDs. Live Price IDs are
# DIFFERENT from their test-mode counterparts and must exist in Stripe Live mode.
# These are SECRETS (except the price IDs and base URL): server-side only, never
# commit real values. Set them in Vercel → Settings → Environment Variables.
STRIPE_SECRET_KEY=sk_live_xxx                 # Live mode → Developers → API keys → Secret key
STRIPE_WEBHOOK_SECRET=whsec_xxx               # Signing secret of the LIVE webhook endpoint (POST /api/stripe/webhook)
# Price IDs (not secret — they only identify a price, they cannot charge anyone).
# Each must be a LIVE-mode price id when using live keys above.
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
# Break Into Construction Management membership terms. Monthly falls back to the
# starter price when unset; the longer terms need their own live price ids.
STRIPE_MONTHLY_PRICE_ID=price_xxx
STRIPE_QUARTERLY_PRICE_ID=price_xxx
STRIPE_BIANNUAL_PRICE_ID=price_xxx
# Public base URL used to build Stripe success/cancel/return URLs (e.g. https://app.example.com).
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Nutrient.io (DWS API) keys — see docs/nutrient-io-integration.md
# Live keys look like `pdf_live_...`. Set real values in Vercel + local .env.local.
# These are SECRETS: do not commit real values. Server-side only (no NEXT_PUBLIC_).
NUTRIENT_PROCESSOR_API_KEY=pdf_live_xxx_processor
NUTRIENT_DATA_EXTRACTION_API_KEY=pdf_live_xxx_data_extraction
NUTRIENT_ACCESSIBILITY_API_KEY=pdf_live_xxx_accessibility
NUTRIENT_LIVE_API_KEY=pdf_live_xxx_general

# Career Center job aggregation (lib/jobs.ts). All providers are optional —
# with no keys the /careers page falls back to direct job-board search links.
# JSearch (via RapidAPI) surfaces postings published to LinkedIn, Indeed,
# Glassdoor, ZipRecruiter, etc. through Google for Jobs.
JSEARCH_API_KEY=your_rapidapi_key_subscribed_to_jsearch
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
# ADZUNA_COUNTRY=us
# Jooble — broad job aggregator. Get a key at https://jooble.org/api/about
JOOBLE_API_KEY=your_jooble_api_key
