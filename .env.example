# Nutrient.io (DWS API) keys — see docs/nutrient-io-integration.md
# Live keys look like `pdf_live_...`. Set real values in Vercel + local .env.local.
# These are SECRETS: do not commit real values. Server-side only (no NEXT_PUBLIC_).
NUTRIENT_PROCESSOR_API_KEY=pdf_live_xxx_processor
NUTRIENT_DATA_EXTRACTION_API_KEY=pdf_live_xxx_data_extraction
NUTRIENT_ACCESSIBILITY_API_KEY=pdf_live_xxx_accessibility
NUTRIENT_LIVE_API_KEY=pdf_live_xxx_general

# Career Center job aggregation (lib/jobs.ts). Both providers are optional —
# with no keys the /careers page falls back to direct job-board search links.
# JSearch (via RapidAPI) surfaces postings published to LinkedIn, Indeed,
# Glassdoor, ZipRecruiter, etc. through Google for Jobs.
JSEARCH_API_KEY=your_rapidapi_key_subscribed_to_jsearch
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
# ADZUNA_COUNTRY=us
